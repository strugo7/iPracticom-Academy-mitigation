# ============================================================================
# iPracticom Academy — .env.example
# העתק ל-.env.local ומלא ערכים. .env.local לעולם לא נכנס ל-git.
# רק משתנים בקידומת VITE_ נחשפים ל-frontend (Vite). אין לשים כאן סודות-שרת.
# ============================================================================

# ── מערכות ארגוניות בסרגל הניווט (מסמך 30, שלב 0.5) ────────────────────────
# דריסת ברירות המחדל שב-src/config/externalSystems.ts; בעתיד ינוהל מ-AppSetting.
VITE_EXT_FIREBERRY_URL=
VITE_EXT_PRIORITY_URL=
VITE_EXT_MECKANO_URL=""
VITE_EXT_HADSHANUT_URL=
VITE_EXT_INTERNAL_APP_URL="https://tools.ip-com.co.il"
VITE_EXT_DRIVE_URL=

# ── שכבת ה-API (מסמך 36, שלבים 0.3 + 11.1) ─────────────────────────────────
# עד קבלת ה-API הפנים-ארגוני עובדים מול mock. החלף ל-real דרך ה-factory.
VITE_USE_MOCK=true
VITE_API_BASE_URL=
VITE_API_KEY=

# ============================================================================
# הערה ארכיטקטונית (מסמך 37):
# המשתנים הבאים ממסמך 34 חלק ה שייכים ל-API/Backend שצוות הפיתוח בונה
# (MySQL, Auth, אחסון, אינטגרציות). ה-frontend שלנו לא צורך אותם ישירות —
# הוא פונה רק ל-VITE_API_BASE_URL. מתועדים כאן כ-reference בלבד, לא לשימוש
# ב-frontend, ולעולם לא בקוד. סודות אלה מנוהלים בצד השרת.
# ----------------------------------------------------------------------------
# Auth (Phase 12 — צוות הפיתוח):      GOOGLE_CLIENT_ID / SECRET, INVITE_JWT_SECRET, JWT_SECRET
# Email:                              RESENDER_SECRET
# AI / LLM:                           OPENROUTER_API_KEY, CLAUDE_API_KEY
# n8n:                               N8N_WEBHOOK_URL, N8N_QUIZ_WEBHOOK_URL, N8N_FLIPBOOK_WEBHOOK, N8N_WEBHOOK_SECRET
# Gamma:                             GAMMA_N8N_WEBHOOK_URL, GAMMA_CALLBACK_URL, GAMMA_WEBHOOK_SECRET, GAMMA_TEMPLATE_*
# Storage (אחסון בשרת החברה):         CLOUDFLARE_R2_* (או חלופת החברה)
# PDF:                               PDF_SERVICE_CLIENT_ID, PDF_SERVICES_CLIENT_SECRET
# Pexels:                            PEXELS_API_KEY
# Google Docs/Slides:                GOOGLE_DOCS_CLIENT_ID / SECRET
# Internal:                          ACADEMY_API_KEY, ASSET_KEY
# ============================================================================
